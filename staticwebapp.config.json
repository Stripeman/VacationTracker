{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{json,js,css,png,jpg,svg,ico}"]
  },
  "routes": [
    { "route": "/api/trips", "methods": ["GET"] },
    { "route": "/api/trips", "methods": ["POST", "PUT"], "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "statusCode": 401 }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
